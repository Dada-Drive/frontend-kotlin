# Gradle build outputs (wrapper files ARE tracked per Gradle convention)
gradle/wrapper/dists/

# Android / Kotlin
*.iml
.gradle/
/local.properties
/.idea/
.DS_Store
/build/
*.apk

# AAR files: ignored EXCEPT vendor libraries in app/libs/
*.aar
!app/libs/*.aar

# Decompressed/extracted AAR contents (build artifacts, never tracked)
app/libs/_tmp_here/
app/libs/_extracted/
app/libs/hereunz_out/
app/libs/hereunz.zip

/captures/
.externalNativeBuild/
.cxx/

# IDE
*.iws
*.ipr

# Secrets - ne jamais committer
google-services.json
local.properties
client_secret_*.json
*.keystore
*.jks
*.key

# Kotlin / JVM build outputs (vendor jars in app/libs/ ARE tracked)
.kotlin/
*.class
*.war
*.ear

# OS
Thumbs.db
ehthumbs.db
Desktop.ini
