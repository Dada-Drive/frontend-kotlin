# Simple flat rectangular/quad-shaped model
o Rectangle

# Vertices
v -0.5 0.5 0.0
v -0.5 -0.5 0.0
v  0.5 -0.5 0.0
v  0.5  0.5 0.0

# Texture coordinates (optional)
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

# Normal (optional, for lighting calculations)
vn 0.0 0.0 1.0

# Face definitions (with vertex, texture, and normal indices)
f 1/1/1 2/2/1 3/3/1 4/4/1
